generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ========================
// USER MANAGEMENT
// ========================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  role         UserRole @default(VIEWER)
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  uploads      Upload[]
  auditLogs    AuditLogBatch[]
  sessions     Session[]
  chatMessages ChatMessage[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
  MANAGER
}

// ========================
// SAP MASTER DATA - NEW
// ========================
model CustomerMaster {
  id                String       @id @default(cuid())
  customerNumber    String       @unique // SAP SOLD_TO partner
  companyName       String
  salesOrg          String       @default("1000")
  distChannel       String       @default("10")
  division          String       @default("00")
  paymentTerms      String       @default("D30")
  shippingCondition String       @default("01")
  country           String
  region            String?
  city              String?
  address           String?
  creditLimit       Float?
  creditStatus      CreditStatus @default(ACTIVE)
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relations
  orderBatches      OrderBatch[]
  pricingConditions PricingCondition[]
}

enum CreditStatus {
  ACTIVE
  HOLD
  BLOCKED
}

model MaterialMaster {
  id              String   @id @default(cuid())
  materialNumber  String   @unique // SAP material/SKU code
  description     String
  baseUom         String   @default("EA")
  salesUom        String   @default("EA")
  plant           String   @default("1000")
  storageLocation String?
  materialGroup   String?
  category        String?
  subCategory     String?
  priceUsd        Float?
  costUsd         Float?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  pricingConditions PricingCondition[]
  orderLines        OrderLineBatch[]
}

model PricingCondition {
  id             String    @id @default(cuid())
  conditionType  String // PR00, K004, MWST, KF00
  materialNumber String?
  customerNumber String?
  salesOrg       String    @default("1000")
  amount         Float // Store as Float for SQLite
  currency       String    @default("USD")
  validFrom      DateTime  @default(now())
  validTo        DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  material MaterialMaster? @relation(fields: [materialNumber], references: [materialNumber])
  customer CustomerMaster? @relation(fields: [customerNumber], references: [customerNumber])
}

// ========================
// ORDER BATCH PROCESSING - NEW
// ========================
model OrderBatch {
  id                  String      @id @default(cuid())
  batchName           String
  fileName            String // original uploaded file name
  fileUrl             String // stored file path
  totalOrders         Int         @default(0)
  successCount        Int         @default(0)
  failedCount         Int         @default(0)
  pendingCount        Int         @default(0)
  status              BatchStatus @default(UPLOADED)
  aiMappingConfidence Float?
  uploadedBy          String
  mappingConfig       String? // JSON of column mappings
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  orderLines       OrderLineBatch[]
  auditLogs        AuditLogBatch[]
  customerMaster   CustomerMaster?  @relation(fields: [customerMasterId], references: [id])
  customerMasterId String?
}

enum BatchStatus {
  UPLOADED
  VALIDATING
  AI_MAPPING
  VALIDATED
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL_SUCCESS
}

model OrderLineBatch {
  id                    String    @id @default(cuid())
  batchId               String
  rowIndex              Int // row number from Excel
  orderType             String    @default("OR") // Standard order
  salesOrg              String    @default("1000")
  distChannel           String    @default("10")
  division              String    @default("00")
  soldTo                String // customer code
  shipTo                String // delivery location
  material              String // SKU
  quantity              Float // Store as Float for SQLite
  unitPrice             Float?
  lineTotal             Float?
  requestedDeliveryDate DateTime?
  plant                 String    @default("1000")
  poNumber              String?
  currency              String    @default("USD")

  // SAP Integration
  sapOrderNumber   String? // returned from SAP after creation
  sapItemNumber    String? // SAP line item number
  status           LineStatus @default(PENDING)
  validationErrors String? // JSON string of error messages
  sapResponse      String? // JSON string of SAP response
  retryCount       Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  batch          OrderBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  materialMaster MaterialMaster? @relation(fields: [material], references: [materialNumber])
}

enum LineStatus {
  PENDING
  VALIDATING
  VALID
  INVALID
  PROCESSING
  CREATED
  FAILED
}

model AuditLogBatch {
  id         String   @id @default(cuid())
  userId     String?
  action     String // UPLOAD, VALIDATE, CREATE_ORDER, etc.
  entityType String // OrderBatch, OrderLine, etc.
  entityId   String
  details    String? // JSON string
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  // Relations
  user  User?       @relation(fields: [userId], references: [id])
  batch OrderBatch? @relation(fields: [entityId], references: [id])
}

// ========================
// UPLOAD & DATA IMPORT (Legacy support)
// ========================
model Upload {
  id            String       @id @default(cuid())
  userId        String
  fileName      String
  fileUrl       String
  fileSize      Int
  fileType      String // xlsx, csv, etc.
  rowsTotal     Int          @default(0)
  rowsSuccess   Int          @default(0)
  rowsFailed    Int          @default(0)
  status        UploadStatus @default(PENDING)
  errorReport   String?
  mappingConfig String? // JSON of column mappings
  processedAt   DateTime?
  createdAt     DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum UploadStatus {
  PENDING
  VALIDATING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// ========================
// EXISTING MODELS (for backwards compatibility)
// ========================
model Order {
  id                    String        @id
  orderNumber           String?       @unique
  orderDate             DateTime
  customerId            String
  status                OrderStatus   @default(CREATED)
  totalAmount           Float?
  currency              String        @default("USD")
  requestedDeliveryDate DateTime?
  requiredShipDate      DateTime? // RSD
  poNumber              String?
  paymentStatus         PaymentStatus @default(PENDING)
  creditReleased        Boolean       @default(false)
  creditReleasedAt      DateTime?
  sapOrderNumber        String?
  sapStatus             String?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  uploadId              String?

  // Relations
  lines          OrderLine[]
  statusHistory  OrderStatusHistory[]
  allocations    OrderAllocation[]
  creditReleases CreditRelease[]
  invoice        Invoice?
  container      Container?
  kitAllocations KitAllocation[]
}

enum OrderStatus {
  CREATED
  PENDING
  CONFIRMED
  ALLOCATED
  SHIPPED
  DELIVERED
  INVOICED
  CANCELLED
  BLOCKED
}

enum PaymentStatus {
  PENDING
  CREDIT_HOLD
  CREDIT_RELEASED
  PAID
  PARTIAL
  OVERDUE
}

model OrderLine {
  id          String @id @default(cuid())
  orderId     String
  materialId  String
  quantity    Int
  unitPrice   Float
  lineTotal   Float
  discountPct Float  @default(0)

  // Relations
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id])

  @@unique([orderId, materialId])
}

model OrderStatusHistory {
  id         String   @id @default(cuid())
  orderId    String
  fromStatus String?
  toStatus   String
  changedAt  DateTime @default(now())
  changedBy  String?
  notes      String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderAllocation {
  id                  String   @id @default(cuid())
  orderId             String
  materialId          String
  allocatedQty        Int
  allocatedDate       DateTime @default(now())
  rsd                 DateTime // Required Shipment Date
  shelfLifeConstraint Int      @default(180) // Days (6 months default)
  creditBlocked       Boolean  @default(false)
  blockedReason       String?
  allocatedBy         String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model CreditRelease {
  id         String              @id @default(cuid())
  customerId String
  orderId    String
  releasedBy String
  releasedAt DateTime            @default(now())
  status     CreditReleaseStatus @default(APPROVED)
  notes      String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum CreditReleaseStatus {
  PENDING
  APPROVED
  REJECTED
}

model Invoice {
  id            String        @id @default(cuid())
  orderId       String        @unique
  invoiceNumber String        @unique
  invoiceDate   DateTime
  dueDate       DateTime?
  amount        Float
  taxAmount     Float         @default(0)
  totalAmount   Float
  currency      String        @default("USD")
  status        InvoiceStatus @default(DRAFT)
  sapDocNumber  String?
  sapMigoDoc    String?
  sapMiroDoc    String?
  sentAt        DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

model Vendor {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  country      String
  city         String?
  address      String?
  email        String?
  phone        String?
  leadTimeDays Int      @default(30)
  paymentTerms String   @default("NET30")
  incoTerms    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  materials VendorMaterial[]
}

model Port {
  id        String  @id @default(cuid())
  code      String  @unique
  name      String
  country   String
  region    String?
  latitude  Float?
  longitude Float?
  timezone  String?
  isActive  Boolean @default(true)

  originContainers      Container[] @relation("OriginPort")
  destinationContainers Container[] @relation("DestinationPort")
}

model Container {
  id                String          @id @default(cuid())
  containerNumber   String          @unique
  orderId           String          @unique
  shippingLine      String?
  vesselName        String?
  voyageNumber      String?
  originPortId      String?
  destinationPortId String?
  etd               DateTime? // Estimated Time of Departure
  eta               DateTime? // Estimated Time of Arrival
  ata               DateTime? // Actual Time of Arrival
  status            ContainerStatus @default(BOOKED)
  trackingUrl       String?
  blNumber          String? // Bill of Lading
  sealNumber        String?
  containerType     String? // 20GP, 40GP, 40HQ, etc.
  weightKg          Float?
  volumeCbm         Float?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  order           Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  originPort      Port?                    @relation("OriginPort", fields: [originPortId], references: [id])
  destinationPort Port?                    @relation("DestinationPort", fields: [destinationPortId], references: [id])
  statusHistory   ContainerStatusHistory[]
}

enum ContainerStatus {
  BOOKED
  GATE_IN
  LOADED
  DEPARTED
  IN_TRANSIT
  ARRIVED
  DISCHARGED
  GATE_OUT
  DELIVERED
}

model ContainerStatusHistory {
  id          String   @id @default(cuid())
  containerId String
  status      String
  location    String?
  timestamp   DateTime @default(now())
  notes       String?

  container Container @relation(fields: [containerId], references: [id], onDelete: Cascade)
}

model InventoryRecord {
  id               String    @id @default(cuid())
  materialId       String
  month            DateTime
  openingStock     Int
  stockInTransit   Int       @default(0)
  actualSales      Int       @default(0)
  closingStock     Int
  safetyStock      Int
  replenishmentQty Int
  expiryDate       DateTime?
  batchDate        DateTime?
  warehouseCode    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  material         Material  @relation(fields: [materialId], references: [id])

  @@unique([materialId, month])
}

model ForecastRecord {
  id               String   @id @default(cuid())
  materialId       String
  month            DateTime
  forecastDemand   Int
  actualDemand     Int?
  forecastAccuracy Float?
  confidenceLower  Int?
  confidenceUpper  Int?
  modelUsed        String   @default("gemini-moving-avg")
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  material         Material @relation(fields: [materialId], references: [id])

  @@unique([materialId, month])
}

model InventoryAgeConfig {
  id          String   @id @default(cuid())
  name        String
  goodMaxDays Int      @default(180) // 6 months
  slowMaxDays Int      @default(365) // 12 months
  isDefault   Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BOM {
  id          String   @id @default(cuid())
  skuId       String // The finished product SKU
  version     Int      @default(1)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines           BOMLine[]
  productionPlans ProductionPlan[]
}

model BOMLine {
  id             String       @id @default(cuid())
  bomId          String
  materialId     String
  materialType   MaterialType @default(RM)
  quantity       Float
  uom            String       @default("EA")
  wastagePercent Float        @default(0)
  isOptional     Boolean      @default(false)
  sortOrder      Int          @default(0)

  bom      BOM      @relation(fields: [bomId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id])
}

enum MaterialType {
  RM // Raw Material
  PM // Packaging Material
  SF // Semi-Finished
  FG // Finished Good
}

model ProductionPlan {
  id          String           @id @default(cuid())
  bomId       String
  skuId       String
  plannedDate DateTime
  quantity    Int
  status      ProductionStatus @default(PLANNED)
  priority    Int              @default(5)
  notes       String?
  createdBy   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  bom BOM @relation(fields: [bomId], references: [id])
}

enum ProductionStatus {
  PLANNED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DELAYED
}

model VendorMaterial {
  id          String    @id @default(cuid())
  vendorId    String
  materialId  String
  price       Float
  currency    String    @default("USD")
  moq         Int? // Minimum Order Quantity
  leadTime    Int       @default(30) // Days
  validFrom   DateTime  @default(now())
  validTo     DateTime?
  isPreferred Boolean   @default(false)

  vendor   Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id])

  @@unique([vendorId, materialId])
}

model MaterialETA {
  id          String    @id @default(cuid())
  materialId  String
  vendorId    String
  containerId String?
  etaDate     DateTime
  quantity    Int
  status      ETAStatus @default(EXPECTED)
  orderRef    String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  material    Material  @relation(fields: [materialId], references: [id])
}

enum ETAStatus {
  EXPECTED
  CONFIRMED
  SHIPPED
  IN_TRANSIT
  DELAYED
  ARRIVED
}

model KitMaster {
  id            String   @id @default(cuid())
  kitSkuId      String   @unique
  kitName       String
  description   String?
  kitMaterialId String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  kitMaterial Material        @relation("KitMasterMaterial", fields: [kitMaterialId], references: [id])
  components  KitComponent[]
  allocations KitAllocation[]
}

model Material {
  id              String   @id
  description     String
  category        String?
  subCategory     String?
  baseUom         String   @default("EA")
  salesUom        String   @default("EA")
  plant           String   @default("DXB1")
  storageLocation String?
  priceUsd        Float
  costUsd         Float?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orderLines       OrderLine[]
  inventoryRecords InventoryRecord[]
  forecastRecords  ForecastRecord[]
  bomLines         BOMLine[]
  vendorMaterials  VendorMaterial[]
  materialETAs     MaterialETA[]
  kitComponents    KitComponent[]  @relation("KitComponentMaterial")
  kitMasters       KitMaster[]     @relation("KitMasterMaterial")
}

model KitComponent {
  id             String  @id @default(cuid())
  kitMasterId    String
  componentSkuId String
  quantity       Float
  uom            String  @default("EA")
  isOptional     Boolean @default(false)

  kitMaster KitMaster @relation(fields: [kitMasterId], references: [id], onDelete: Cascade)
  component Material  @relation("KitComponentMaterial", fields: [componentSkuId], references: [id])
}

model KitAllocation {
  id            String              @id @default(cuid())
  kitMasterId   String
  orderId       String
  quantity      Int
  allocatedDate DateTime            @default(now())
  status        KitAllocationStatus @default(PLANNED)
  allocatedBy   String?
  notes         String?

  kitMaster KitMaster @relation(fields: [kitMasterId], references: [id])
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum KitAllocationStatus {
  PLANNED
  ALLOCATED
  ASSEMBLED
  READY
  SHIPPED
  CANCELLED
}

model SavedReport {
  id          String     @id @default(cuid())
  name        String
  type        ReportType
  description String?
  filters     String? // JSON of saved filters
  config      String? // JSON of report configuration
  createdBy   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  lastRunAt   DateTime?

  schedules ReportSchedule[]
}

enum ReportType {
  ABC_ANALYSIS
  INVENTORY_HEALTH
  ORDER_SUMMARY
  FORECAST_ACCURACY
  CONTAINER_TRACKING
  PRODUCTION_PLAN
  KITTING_STATUS
  CUSTOM
}

model ReportSchedule {
  id         String            @id @default(cuid())
  reportId   String
  frequency  ScheduleFrequency
  dayOfWeek  Int? // 0-6 for weekly
  dayOfMonth Int? // 1-31 for monthly
  timeOfDay  String // HH:mm format
  recipients String // Comma-separated emails
  isActive   Boolean           @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime?
  createdAt  DateTime          @default(now())

  report SavedReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String // user, assistant, system
  content   String
  toolsUsed String? // JSON of tools used
  context   String? // JSON of conversation context
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Scenario {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String // DEMAND_ADJUST, SAFETY_STOCK, etc.
  params      String // JSON of scenario parameters
  results     String? // JSON of scenario results
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompanySettings {
  id                    String   @id @default(cuid())
  companyName           String   @default("TenchiOne")
  logoUrl               String?
  primaryColor          String   @default("#e89a2d")
  currency              String   @default("USD")
  fiscalYearStart       Int      @default(1) // Month number
  safetyStockMultiplier Float    @default(1.5)
  forecastHorizon       Int      @default(12) // Months
  defaultAgeConfigId    String?
  emailNotifications    Boolean  @default(true)
  sapIntegration        Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
