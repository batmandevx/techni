# Database - PostgreSQL for SmartOrder Engine
DATABASE_URL=postgresql://user:password@localhost:5432/smartorder

# Auth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# SAP Connection
SAP_HOST=
SAP_SYSNR=00
SAP_CLIENT=100
SAP_USER=
SAP_PASSWORD=
SAP_MOCK=true
SAP_SERVICE_URL=http://localhost:8000

# File Storage
UPLOAD_DIR=./uploads

# App
NODE_ENV=development
