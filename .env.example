# ─── Required ────────────────────────────────────────────────────────────────

# Google Gemini AI — used for Excel column mapping in SmartOrder upload
GEMINI_API_KEY=your_gemini_api_key_here

# ─── SmartOrder Storage ───────────────────────────────────────────────────────

# "file" (default) uses data/smart-order-store.json — no database needed
# "prisma" requires DATABASE_URL set to a PostgreSQL connection string
SMARTORDER_STORAGE=file

# ─── SAP Integration ──────────────────────────────────────────────────────────

# Set to "false" to enable real SAP RFC calls (requires PyRFC sap-service config)
SAP_MOCK=true
SAP_SERVICE_URL=http://localhost:8000

# ─── Optional: Clerk Authentication ──────────────────────────────────────────
# Leave blank to run without authentication (auth page will be a simple form)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth

# ─── Optional: Database (only if SMARTORDER_STORAGE=prisma) ──────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/smartorder

# ─── Optional: App URL (for CORS headers in production) ──────────────────────
# NEXTAUTH_URL=https://your-domain.com
