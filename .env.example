# ============================================
# Tenchi S&OP Platform - Environment Variables
# ============================================

# --------------------------------------------
# Required Settings
# --------------------------------------------

# Application URL (Required)
# Set to your production domain for production deployments
NEXTAUTH_URL="http://localhost:3000"

# Secret key for JWT encryption (Required)
# Generate a random string with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-min-32-characters-long"

# --------------------------------------------
# Database (Optional - uses localStorage by default)
# --------------------------------------------

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/tenchi_sop?schema=public"

# --------------------------------------------
# AI Features (Optional)
# --------------------------------------------

# Google Gemini API Key for AI assistant
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# --------------------------------------------
# Email Notifications (Optional)
# --------------------------------------------

# SMTP Configuration for email notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@tenchi-sop.com"

# --------------------------------------------
# Redis/Cache (Optional)
# --------------------------------------------

# Upstash Redis for caching and session storage
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# --------------------------------------------
# OAuth Providers (Optional)
# --------------------------------------------

# Google OAuth for authentication
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --------------------------------------------
# File Storage (Optional)
# --------------------------------------------

# Vercel Blob for file storage
BLOB_READ_WRITE_TOKEN="your-blob-token"

# --------------------------------------------
# Monitoring (Optional)
# --------------------------------------------

# Sentry DSN for error tracking
SENTRY_DSN=""

# Log level (debug, info, warn, error)
LOG_LEVEL="info"
