# ============================================
# Tenchi S&OP Platform - Environment Variables
# ============================================

# --------------------------------------------
# Required Settings: Clerk Authentication
# --------------------------------------------

# Get these from https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Application URL (Required)
# Set to your production domain for production deployments
NEXTAUTH_URL="http://localhost:3000"

# --------------------------------------------
# Database and SmartOrder storage
# --------------------------------------------

# Prisma database connection string
DATABASE_URL="postgresql://user:password@localhost:5432/smartorder?schema=public"

# SmartOrder storage mode: auto, file, prisma
# auto   -> use Prisma when available, otherwise fall back to the file-backed store
# file   -> always use the file-backed store
# prisma -> require Prisma and fail fast if the database/client is unavailable
SMARTORDER_STORAGE="auto"

# --------------------------------------------
# AI Features (Optional)
# --------------------------------------------

# Google Gemini API Key for AI assistant
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# SmartOrder upload directory
UPLOAD_DIR="./uploads"

# --------------------------------------------
# Email Notifications (Optional)
# --------------------------------------------

# SMTP Configuration for email notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@tenchi-sop.com"

# --------------------------------------------
# Redis/Cache (Optional)
# --------------------------------------------

# Upstash Redis for caching and session storage
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"
REDIS_URL="redis://localhost:6379"

# --------------------------------------------
# OAuth Providers (Optional)
# --------------------------------------------

# Google OAuth for authentication
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --------------------------------------------
# File Storage (Optional)
# --------------------------------------------

# Vercel Blob for file storage
BLOB_READ_WRITE_TOKEN="your-blob-token"

# SAP mock / real integration
SAP_SERVICE_URL="http://localhost:8000"
SAP_HOST=""
SAP_SYSNR="00"
SAP_CLIENT="100"
SAP_USER=""
SAP_PASSWORD=""
SAP_MOCK="true"

# --------------------------------------------
# Monitoring (Optional)
# --------------------------------------------

# Sentry DSN for error tracking
SENTRY_DSN=""

# Log level (debug, info, warn, error)
LOG_LEVEL="info"
