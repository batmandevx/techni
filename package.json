{
  "name": "tenchi-sop-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "export": "next export",
    "analyze": "cross-env ANALYZE=true next build",
    "docker:build": "docker build -t tenchi-sop:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env.local tenchi-sop:latest",
    "docker:compose": "docker-compose up -d",
    "docker:compose:db": "docker-compose --profile with-db up -d",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@tanstack/react-table": "^8.13.0",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.344.0",
    "next": "14.2.0",
    "nodemailer": "^6.9.11",
    "pdfjs-dist": "^4.0.379",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.4.1",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^7.7.1",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^2.15.4",
    "three": "^0.161.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/three": "^0.161.0",
    "autoprefixer": "^10.4.17",
    "cross-env": "^7.0.3",
